<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20250001000000-1" author="custom" failOnError="false">
        <createTable tableName="perfil">
            <column name="id" type="integer" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre_perfil" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="bit_administrador" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Datos iniciales: perfil administrador y perfil usuario -->
    <changeSet id="20250001000000-2" author="custom" failOnError="false">
        <insert tableName="perfil">
            <column name="id" valueNumeric="1"/>
            <column name="nombre_perfil" value="Administrador"/>
            <column name="bit_administrador" valueBoolean="true"/>
        </insert>
        <insert tableName="perfil">
            <column name="id" valueNumeric="2"/>
            <column name="nombre_perfil" value="Usuario"/>
            <column name="bit_administrador" valueBoolean="false"/>
        </insert>
    </changeSet>

    <changeSet id="20250001000000-3" author="custom" failOnError="false">
        <sql dbms="mssql">
            IF NOT EXISTS (SELECT 1 FROM perfil WHERE id = 1)
            BEGIN
                SET IDENTITY_INSERT perfil ON;
                INSERT INTO perfil (id, nombre_perfil, bit_administrador) VALUES (1, 'Administrador', 1);
                SET IDENTITY_INSERT perfil OFF;
            END

            IF NOT EXISTS (SELECT 1 FROM perfil WHERE id = 2)
            BEGIN
                SET IDENTITY_INSERT perfil ON;
                INSERT INTO perfil (id, nombre_perfil, bit_administrador) VALUES (2, 'Usuario', 0);
                SET IDENTITY_INSERT perfil OFF;
            END
        </sql>
    </changeSet>

</databaseChangeLog>
